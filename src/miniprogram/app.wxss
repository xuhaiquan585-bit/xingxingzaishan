page {
  min-height: 100%;
  background:
    radial-gradient(circle at 12% 0%, rgba(212, 175, 55, .07), transparent 28%),
    radial-gradient(circle at 92% 14%, rgba(118, 151, 255, .12), transparent 30%),
    linear-gradient(170deg, #07123a 0%, #121f55 54%, #223167 100%);
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 32rpx 112rpx;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 10% 0%, rgba(212, 175, 55, .065), transparent 28%),
    radial-gradient(circle at 90% 10%, rgba(126, 155, 255, .11), transparent 32%),
    linear-gradient(170deg, #07123a 0%, #121f55 54%, #223167 100%);
}

.page::before {
  content: "";
  position: absolute;
  top: -170rpx;
  right: -210rpx;
  width: 430rpx;
  height: 430rpx;
  border-radius: 50%;
  background: rgba(212, 175, 55, .045);
  pointer-events: none;
}

.page::after {
  content: "";
  position: absolute;
  left: -220rpx;
  bottom: -180rpx;
  width: 520rpx;
  height: 420rpx;
  border-radius: 50%;
  background: rgba(95, 127, 255, .07);
  pointer-events: none;
}

.hero-title {
  position: relative;
  z-index: 1;
  max-width: 620rpx;
  margin: 0 0 14rpx;
  color: #e4c46e;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.32;
  letter-spacing: 0;
}

.subtitle {
  position: relative;
  z-index: 1;
  max-width: 640rpx;
  margin: 0 0 34rpx;
  color: rgba(255, 255, 255, .74);
  font-size: 28rpx;
  line-height: 1.62;
}

.card {
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  width: 100%;
  margin: 0 0 28rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .04);
  box-shadow: 0 22rpx 56rpx rgba(4, 10, 38, .16), inset 0 1rpx 0 rgba(255, 255, 255, .06);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  margin: 22rpx 0 0;
  border-radius: 999rpx;
  background: #d4af37;
  color: #141414;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(212, 175, 55, .22);
}

.btn::after {
  border: 0;
}

.btn.secondary {
  border: 1rpx solid rgba(255, 255, 255, .12);
  background: rgba(255, 255, 255, .045);
  color: rgba(255, 255, 255, .88);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .05);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.input,
.textarea {
  box-sizing: border-box;
  width: 100%;
  margin: 14rpx 0 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, .09);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .04);
  color: #fff;
  box-shadow: inset 0 6rpx 18rpx rgba(2, 7, 28, .18), inset 0 1rpx 0 rgba(255, 255, 255, .05);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.textarea {
  min-height: 180rpx;
}

.hint,
.meta {
  position: relative;
  z-index: 1;
  color: rgba(255, 255, 255, .62);
  font-size: 24rpx;
  line-height: 1.7;
}

.state-card {
  box-sizing: border-box;
  width: 100%;
  margin-top: 26rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .035);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .05);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.cover {
  width: 100%;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, .2);
}

.list-title {
  color: #e4c46e;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.36;
}

.hidden {
  display: none;
}
