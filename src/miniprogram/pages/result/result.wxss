.result-image {
  height: 500rpx;
  margin-bottom: 26rpx;
  box-shadow: 0 18rpx 42rpx rgba(3, 8, 32, .24);
}

.memory-content {
  color: #fff;
  font-family: "Songti SC", STSong, serif;
  font-size: 32rpx;
  line-height: 1.82;
}

.brand-disclosure-line {
  margin-top: 22rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, .22);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .04);
  color: rgba(228, 196, 110, .92);
  font-size: 25rpx;
  line-height: 1.55;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .06);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.hash,
.comment-item {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .04);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .05);
  word-break: break-all;
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.hash {
  color: rgba(255, 255, 255, .64);
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-size: 22rpx;
  line-height: 1.6;
}

.comment-item {
  color: rgba(255, 255, 255, .82);
  line-height: 1.7;
}

.list-title {
  margin-top: 28rpx;
}
