.result-page {
  background:
    radial-gradient(
      circle at 92% 4%,
      rgba(244, 194, 142, .16),
      transparent 48%
    ),
    linear-gradient(
      180deg,
      #C9D8E6 0%,
      #E2E9ED 42%,
      #F0EEE8 100%
    );
  color: #263445;
}

.result-page::before,
.result-page::after {
  display: none;
}

.result-page .hero-title {
  color: #223147;
}

.result-page .subtitle {
  color: #68798A;
}

.result-page .meta {
  color: #68798A;
}

.result-card {
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}

.result-image {
  display: block;
  max-height: 680rpx;
  margin-bottom: 28rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .78);
  box-shadow: 0 10rpx 30rpx rgba(66, 79, 91, .08);
}

.memory-content {
  padding: 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .62);
  color: #263445;
  font-family: "Songti SC", STSong, serif;
  font-size: 32rpx;
  line-height: 1.82;
  overflow-wrap: break-word;
}

.result-meta-group {
  margin-top: 24rpx;
  padding: 22rpx;
  border: 1px solid rgba(52, 72, 91, .10);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .46);
}

.result-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  color: #526576;
  font-size: 24rpx;
  line-height: 1.5;
}

.result-row + .result-row {
  margin-top: 12rpx;
}

.result-label {
  color: #8493A1;
}

.result-value {
  color: #526576;
  text-align: right;
}

.mono,
.hash {
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
}

.brand-disclosure-line {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .40);
  color: #68798A;
  font-size: 25rpx;
  line-height: 1.55;
}

.hash,
.comment-item {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .46);
  color: #526576;
  font-size: 24rpx;
  line-height: 1.65;
  overflow-wrap: anywhere;
}

.hash {
  font-size: 22rpx;
}

.comment-item {
  color: #526576;
}

.list-title {
  margin-top: 28rpx;
  color: #223147;
}

.result-primary {
  margin-top: 30rpx;
  border-radius: 14rpx;
  background: #C79E55;
  color: #162230;
  box-shadow: none;
}

.result-secondary {
  margin-top: 18rpx;
  border: 1px solid rgba(52, 72, 91, .16);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, .46);
  color: #223147;
  box-shadow: none;
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}

.result-text-link {
  margin: 18rpx 0 0;
  padding: 0;
  background: transparent;
  color: #A88955;
  font-size: 25rpx;
  line-height: 1.5;
  text-align: left;
}

.result-text-link::after {
  border: 0;
}
