<view class="page orders-page">
  <view class="orders-hero">
    <view class="hero-title">我的订单</view>
    <view class="subtitle">查看酒瓶星贴订单和发货状态。</view>
  </view>

  <view class="order-list">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="card order-card" bindtap="openOrder" data-id="{{item.id}}">
        <image wx:if="{{item.cover_image}}" class="cover order-cover" mode="aspectFill" lazy-load src="{{item.cover_image}}" />
        <view class="list-title">{{item.product_snapshot.title}}</view>
        <view class="hint">{{item.amount_text}} · {{item.status_text}}</view>
        <view class="meta">订单号：{{item.order_no}}</view>
      </view>
    </block>
  </view>

  <view wx:if="{{message}}" class="meta state-card">{{message}}</view>
</view>
