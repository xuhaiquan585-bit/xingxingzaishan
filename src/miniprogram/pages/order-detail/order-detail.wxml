<view class="page order-detail-page">
  <block wx:if="{{order}}">
    <view class="order-hero">
      <view class="hero-title">订单详情</view>
      <view class="subtitle">{{order.status_text}}</view>
    </view>

    <view class="card order-card">
      <image wx:if="{{coverImage}}" class="cover order-cover" mode="aspectFill" src="{{coverImage}}" />
      <view class="list-title">{{order.product_snapshot.title}}</view>
      <view class="hint">{{order.amount_text}} · {{order.quantity}} 件</view>
      <view class="meta">订单号：{{order.order_no}}</view>
      <view class="meta">收货人：{{order.receiver_name}} {{order.receiver_phone}}</view>
      <view class="meta">地址：{{order.region}}{{order.address}}</view>
      <view class="meta" wx:if="{{order.express_no}}">物流：{{order.express_company}} {{order.express_no}}</view>
      <button wx:if="{{order.status === 'pending_payment'}}" class="btn secondary" bindtap="cancelOrder">取消订单</button>
    </view>
  </block>

  <view wx:if="{{message}}" class="meta state-card">{{message}}</view>
</view>
