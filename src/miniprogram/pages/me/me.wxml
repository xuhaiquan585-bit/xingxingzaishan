<view class="page me-page">
  <view class="me-hero">
    <view class="hero-title">我的记录</view>
    <view class="subtitle">你保存过的酒瓶记录，会出现在这里。</view>
    <button class="btn secondary me-order-entry" bindtap="goOrders">我的订单</button>
  </view>

  <view class="record-list">
    <block wx:for="{{records}}" wx:key="id">
      <view class="card record-card" data-id="{{item.id}}" bindtap="openRecord">
        <image wx:if="{{item.image_url}}" class="cover" mode="aspectFill" lazy-load src="{{item.image_url}}" />
        <view class="list-title">{{item.display_content}}</view>
        <view class="record-meta-group">
          <view class="meta">二维码编号：{{item.id}}</view>
          <view class="meta">状态：{{item.status_label}}</view>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{message}}" class="meta state-card">{{message}}</view>
</view>
