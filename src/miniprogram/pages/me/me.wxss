.me-hero,
.record-list {
  position: relative;
  z-index: 1;
}

.me-hero {
  padding: 10rpx 0 8rpx;
}

.me-order-entry {
  margin-top: 20rpx;
}

.record-card {
  padding: 26rpx;
}

.record-card .cover {
  height: 330rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 16rpx 36rpx rgba(3, 8, 32, .2);
}

.record-card .list-title {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  color: #fff;
  font-family: "Songti SC", STSong, serif;
  font-size: 30rpx;
  line-height: 1.58;
}

.record-meta-group {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, .08);
}

.record-meta-group .meta + .meta {
  margin-top: 6rpx;
}
