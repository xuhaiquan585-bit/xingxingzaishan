.bind-phone-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  padding-left: 44rpx;
  padding-right: 44rpx;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(
      circle at 92% 4%,
      rgba(244, 194, 142, .16),
      transparent 48%
    ),
    linear-gradient(
      180deg,
      #C9D8E6 0%,
      #E2E9ED 42%,
      #F0EEE8 100%
    );
  color: #263445;
}

.bind-brand {
  margin-bottom: 72rpx;
  text-align: center;
}

.bind-brand-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(212, 175, 55, .38);
  border-radius: 50%;
  background: rgba(212, 175, 55, .1);
  color: #A88955;
  font-size: 42rpx;
  font-weight: 700;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .06);
}

.bind-phone-page .hero-title {
  color: #223147;
  text-align: center;
}

.bind-phone-page .subtitle {
  margin-bottom: 0;
  color: #68798A;
  text-align: center;
}

.bind-subtitle {
  white-space: pre-line;
}

.bind-login-card {
  padding: 38rpx 32rpx 34rpx;
  border: 1px solid rgba(52, 72, 91, .12);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .58);
  box-shadow: 0 10rpx 30rpx rgba(66, 79, 91, .08);
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}

.bind-login-card .list-title {
  color: #223147;
}

.bind-login-card .hint {
  color: #68798A;
}

.wechat-login-btn {
  box-sizing: border-box;
  width: 460rpx;
  max-width: 100%;
  min-height: 96rpx;
  margin: 36rpx auto 0;
  padding: 0 42rpx;
  border-radius: 14rpx;
  background: #C79E55;
  color: #162230;
  font-size: 30rpx;
  line-height: 1;
  white-space: nowrap;
  box-shadow: none;
}

.wechat-login-btn[disabled] {
  opacity: 0.62;
}

.wechat-mark {
  flex: 0 0 auto;
  margin-right: 16rpx;
  color: #162230;
  font-weight: 800;
  white-space: nowrap;
}

.wechat-login-text {
  flex: 0 0 auto;
  white-space: nowrap;
}

.meta {
  margin-top: 20rpx;
  min-height: 40rpx;
  color: #A45F58;
  text-align: center;
}
