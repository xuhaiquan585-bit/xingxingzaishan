.bind-phone-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  padding-left: 44rpx;
  padding-right: 44rpx;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

.bind-brand {
  margin-bottom: 72rpx;
  text-align: center;
}

.bind-brand-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(212, 175, 55, .38);
  border-radius: 50%;
  background: rgba(212, 175, 55, .1);
  color: #e4c46e;
  font-size: 42rpx;
  font-weight: 700;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .06);
}

.bind-phone-page .hero-title {
  text-align: center;
}

.bind-phone-page .subtitle {
  margin-bottom: 0;
  text-align: center;
}

.bind-login-card {
  padding: 38rpx 32rpx 34rpx;
  border-radius: 24rpx;
}

.wechat-login-btn {
  box-sizing: border-box;
  width: 460rpx;
  max-width: 100%;
  min-height: 96rpx;
  margin: 36rpx auto 0;
  padding: 0 42rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #101010;
  font-size: 30rpx;
  line-height: 1;
  white-space: nowrap;
  box-shadow: 0 14rpx 30rpx rgba(0, 0, 0, .18);
}

.wechat-login-btn[disabled] {
  opacity: 0.62;
}

.wechat-mark {
  flex: 0 0 auto;
  margin-right: 16rpx;
  color: #20c766;
  font-weight: 800;
  white-space: nowrap;
}

.wechat-login-text {
  flex: 0 0 auto;
  white-space: nowrap;
}

.meta {
  margin-top: 20rpx;
  min-height: 40rpx;
}
