.memory-image {
  height: 460rpx;
  margin-bottom: 26rpx;
  box-shadow: 0 18rpx 42rpx rgba(3, 8, 32, .24);
}

.memory-content {
  margin-bottom: 28rpx;
  color: #fff;
  font-family: "Songti SC", STSong, serif;
  font-size: 32rpx;
  line-height: 1.82;
}

.comment-box {
  margin-top: 32rpx;
  padding-top: 8rpx;
}

.comment-item {
  margin-top: 20rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .04);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .05);
  color: rgba(255, 255, 255, .82);
  line-height: 1.7;
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.comment-head {
  color: rgba(228, 196, 110, .92);
  font-size: 24rpx;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
}

.small {
  min-height: 64rpx;
  margin-top: 18rpx;
  font-size: 24rpx;
}

.list-title {
  margin-top: 32rpx;
}
