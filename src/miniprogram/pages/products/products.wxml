<view class="page products-page">
  <view class="products-hero">
    <view class="hero-title">封存</view>
    <view class="subtitle">选择酒瓶星贴，贴在酒瓶上，扫码留下照片和一句话。</view>
  </view>

  <view class="scene-tabs">
    <view
      wx:for="{{sceneOptions}}"
      wx:key="key"
      class="scene-tab {{activeScene === item.key ? 'active' : ''}}"
      bindtap="changeScene"
      data-scene="{{item.key}}"
    >{{item.label}}</view>
  </view>

  <view class="products-context card">
    <view class="list-title">为「{{activeSceneLabel}}」推荐</view>
    <view class="hint">当前商品为酒瓶星贴/印刷贴纸，不含酒水。</view>
  </view>

  <view class="product-list">
    <block wx:for="{{products}}" wx:key="id">
      <view class="card product-card" bindtap="openProduct" data-id="{{item.id}}">
        <image wx:if="{{item.cover_image}}" class="cover" mode="aspectFill" lazy-load src="{{item.cover_image}}" />
        <view class="list-title">{{item.title}}</view>
        <view class="hint">{{item.subtitle}}</view>
        <view class="price">{{item.price_text}}</view>
        <view class="meta">贴纸 {{item.sticker_count}} 枚 · 不含酒水</view>
      </view>
    </block>
  </view>

  <view wx:if="{{message}}" class="meta state-card">{{message}}</view>
</view>
