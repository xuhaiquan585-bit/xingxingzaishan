<view class="page">
  <view class="hero-title">商品展示</view>
  <view class="subtitle">实物酒与礼盒展示，购买入口暂使用快团团链接。</view>

  <block wx:for="{{products}}" wx:key="id">
    <view class="card product-card" bindtap="openProduct" data-id="{{item.id}}">
      <image wx:if="{{item.cover_image}}" class="cover" mode="aspectFill" src="{{item.cover_image}}" />
      <view class="list-title">{{item.title}}</view>
      <view class="hint">{{item.subtitle}}</view>
      <view class="price">{{item.price_text}}</view>
    </view>
  </block>

  <view class="meta">{{message}}</view>
</view>
