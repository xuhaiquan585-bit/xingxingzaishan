.products-hero {
  position: relative;
  z-index: 1;
  padding: 10rpx 0 8rpx;
}

.product-list {
  position: relative;
  z-index: 1;
}

.product-card {
  padding: 26rpx;
}

.product-card .cover {
  height: 420rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 36rpx rgba(3, 8, 32, .2);
}

.product-card .hint {
  margin-top: 12rpx;
}

.price {
  margin-top: 18rpx;
  color: #d4af37;
  font-size: 32rpx;
  font-weight: 700;
}

.product-card {
  transition: transform .18s ease;
}
