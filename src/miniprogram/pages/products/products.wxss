.products-hero {
  position: relative;
  z-index: 1;
  padding: 10rpx 0 8rpx;
}

.scene-tabs {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 14rpx;
  margin: 8rpx 0 24rpx;
  padding-bottom: 6rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.scene-tab {
  flex: 0 0 auto;
  padding: 16rpx 26rpx;
  border: 1rpx solid rgba(255, 255, 255, .1);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .04);
  color: rgba(255, 255, 255, .72);
  font-size: 26rpx;
  font-weight: 650;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .05);
}

.scene-tab.active {
  border-color: rgba(212, 175, 55, .42);
  background: rgba(212, 175, 55, .12);
  color: #e4c46e;
}

.products-context {
  padding: 26rpx;
}

.products-context .hint {
  margin-top: 10rpx;
}

.product-list {
  position: relative;
  z-index: 1;
}

.product-card {
  padding: 26rpx;
}

.product-card .cover {
  height: 420rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 36rpx rgba(3, 8, 32, .2);
}

.product-card .hint {
  margin-top: 12rpx;
}

.price {
  margin-top: 18rpx;
  color: #d4af37;
  font-size: 32rpx;
  font-weight: 700;
}

.product-card {
  transition: transform .18s ease;
}
