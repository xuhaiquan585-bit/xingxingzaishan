.record-page {
  position: relative;
  overflow: hidden;
  padding: 58rpx 28rpx 128rpx;
  padding-bottom: calc(128rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 12% 0%, rgba(212, 175, 55, .07), transparent 28%),
    radial-gradient(circle at 92% 14%, rgba(118, 151, 255, .12), transparent 30%),
    linear-gradient(170deg, #07123a 0%, #121f55 54%, #223167 100%);
}

.record-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.record-glow-top {
  top: -150rpx;
  right: -180rpx;
  width: 340rpx;
  height: 340rpx;
  background: rgba(212, 175, 55, .055);
}

.record-glow-bottom {
  left: -160rpx;
  bottom: 160rpx;
  width: 420rpx;
  height: 420rpx;
  background: rgba(97, 132, 255, .08);
}

.record-hero,
.record-card {
  position: relative;
  z-index: 1;
}

.record-hero {
  padding: 18rpx 4rpx 40rpx;
}

.record-title {
  max-width: 600rpx;
  margin-bottom: 20rpx;
  color: #e4c46e;
  font-size: 46rpx;
  line-height: 1.32;
  font-weight: 700;
  letter-spacing: 0;
}

.trust-line {
  margin-bottom: 20rpx;
  color: rgba(212, 175, 55, .72);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.record-subtitle {
  max-width: 600rpx;
  color: rgba(255, 255, 255, .74);
  font-size: 28rpx;
  line-height: 1.62;
}

.record-card {
  padding: 28rpx;
  border-color: rgba(255, 255, 255, .12);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .055);
  box-shadow: 0 22rpx 56rpx rgba(4, 10, 38, .18), inset 0 1rpx 0 rgba(255, 255, 255, .06);
}

.record-meta-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 10rpx;
  margin-bottom: 18rpx;
  color: rgba(255, 255, 255, .5);
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-size: 22rpx;
}

.record-meta-label {
  color: rgba(255, 255, 255, .42);
}

.record-meta-value {
  color: rgba(255, 255, 255, .68);
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-weight: 600;
  letter-spacing: 0;
}

.photo-frame {
  box-sizing: border-box;
  width: 100%;
  min-height: 410rpx;
  margin: 0 0 34rpx;
  padding: 0;
  border: 0;
  border-radius: 28rpx;
  background: transparent;
  color: #fff;
  line-height: 1.4;
  box-shadow: none;
}

.photo-frame::after {
  border: 0;
}

.photo-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 408rpx;
  border: 1rpx dashed rgba(212, 175, 55, .34);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .035);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .06);
}

.photo-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  margin-bottom: 22rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, .06);
  color: #d4af37;
  font-size: 48rpx;
  line-height: 1;
}

.photo-title {
  color: #fff;
  font-size: 31rpx;
  font-weight: 700;
}

.photo-hint {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .5);
  font-size: 23rpx;
}

.photo-action {
  margin-top: 18rpx;
  color: #d4af37;
  font-size: 25rpx;
  font-weight: 700;
}

.preview {
  display: block;
  margin: 0;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .035);
}

.field-block {
  margin-bottom: 26rpx;
}

.field-title {
  margin-bottom: 14rpx;
  color: rgba(255, 255, 255, .86);
  font-size: 32rpx;
  font-weight: 700;
}

.memory-textarea {
  min-height: 230rpx;
  margin: 0;
  padding: 26rpx;
  border-color: rgba(255, 255, 255, .12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .055);
  box-shadow: inset 0 6rpx 18rpx rgba(2, 7, 28, .18);
  font-family: "Songti SC", STSong, serif;
  font-size: 29rpx;
  line-height: 1.65;
}

.count-row {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .54);
  font-size: 23rpx;
  text-align: right;
}

.mode-cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin: 4rpx 0 30rpx;
}

.mode-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  min-height: 116rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, .12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .045);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .05);
}

.mode-card-active {
  border-color: rgba(212, 175, 55, .62);
  background: rgba(212, 175, 55, .09);
  box-shadow: 0 10rpx 28rpx rgba(212, 175, 55, .08), inset 0 1rpx 0 rgba(255, 255, 255, .06);
}

.mode-radio {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
}

.mode-indicator {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border: 1rpx solid rgba(255, 255, 255, .28);
  border-radius: 50%;
  color: #141414;
  font-size: 21rpx;
  font-weight: 800;
}

.mode-card-active .mode-indicator {
  border-color: #d4af37;
  background: #d4af37;
}

.mode-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

.mode-desc {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, .62);
  font-size: 26rpx;
  line-height: 1.5;
}

.brand-disclosure-card {
  margin: 0 0 30rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, .12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .045);
}

.brand-preview-text {
  margin-bottom: 16rpx;
  color: rgba(255, 255, 255, .64);
  font-size: 24rpx;
  line-height: 1.55;
}

.brand-toggle-row {
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 26rpx;
}

.brand-checkbox {
  transform: scale(.82);
}

.brand-label {
  margin-left: 12rpx;
  color: rgba(255, 255, 255, .88);
}

.record-submit {
  min-height: 96rpx;
  margin-top: 4rpx;
  background: #d4af37;
  box-shadow: 0 16rpx 36rpx rgba(212, 175, 55, .2);
}

.record-footnote {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, .48);
  font-size: 23rpx;
  line-height: 1.6;
  text-align: center;
}

.record-message {
  min-height: 40rpx;
  margin-top: 18rpx;
  text-align: center;
}
