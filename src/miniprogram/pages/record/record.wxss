.record-page {
  position: relative;
  overflow: hidden;
  padding: 58rpx 28rpx 160rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(
      circle at 92% 5%,
      rgba(36, 52, 83, .18),
      transparent 28%
    ),
    linear-gradient(
      180deg,
      #08111E 0%,
      #050B14 100%
    );
}

.record-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.record-glow-top {
  top: -150rpx;
  right: -180rpx;
  width: 340rpx;
  height: 340rpx;
  background: rgba(36, 52, 83, .08);
}

.record-glow-bottom {
  left: 50%;
  bottom: 70rpx;
  width: 520rpx;
  height: 300rpx;
  background: transparent;
  transform: translateX(-50%);
}

.record-hero,
.record-card {
  position: relative;
  z-index: 1;
}

.record-hero {
  padding: 18rpx 4rpx 40rpx;
}

.record-title {
  max-width: 600rpx;
  margin-bottom: 14rpx;
  color: #EDF1F5;
  font-size: 46rpx;
  line-height: 1.32;
  font-weight: 700;
  letter-spacing: 0;
}

.trust-line {
  margin-top: 16rpx;
  color: rgba(197, 164, 94, .78);
  font-size: 23rpx;
  font-weight: 600;
  letter-spacing: .5rpx;
}

.record-subtitle {
  max-width: 600rpx;
  color: #A4AFBD;
  font-size: 28rpx;
  line-height: 1.62;
}

.record-card {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.record-card,
.photo-empty,
.textarea-shell,
.mode-card,
.brand-disclosure-card {
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}

.record-meta-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 10rpx;
  margin-bottom: 18rpx;
  color: rgba(164, 175, 189, .76);
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-size: 22rpx;
}

.record-meta-label {
  color: rgba(164, 175, 189, .62);
}

.record-meta-value {
  color: rgba(237, 241, 245, .78);
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-weight: 600;
  letter-spacing: 0;
}

.photo-frame {
  box-sizing: border-box;
  width: 100%;
  min-height: 280rpx;
  margin: 0 0 34rpx;
  padding: 0;
  border: 0;
  border-radius: 20rpx;
  background: transparent;
  color: #fff;
  line-height: 1.4;
  box-shadow: none;
}

.photo-frame::after {
  border: 0;
}

.photo-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 280rpx;
  border: 1px dashed rgba(197, 164, 94, .28);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .02);
  box-shadow: none;
}

.photo-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  margin-bottom: 22rpx;
  border-radius: 14rpx;
  background: transparent;
  color: #C5A45E;
  font-size: 48rpx;
  line-height: 1;
}

.photo-title {
  color: #EDF1F5;
  font-size: 31rpx;
  font-weight: 700;
}

.photo-hint {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .5);
  font-size: 23rpx;
}

.photo-action {
  margin-top: 18rpx;
  color: #C5A45E;
  font-size: 25rpx;
  font-weight: 700;
}

.preview {
  display: block;
  margin: 0;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .02);
}

.field-block {
  margin-bottom: 26rpx;
}

.field-title {
  margin-bottom: 14rpx;
  color: #EDF1F5;
  font-size: 32rpx;
  font-weight: 700;
}

.textarea-shell {
  position: relative;
  border: 1px solid rgba(255, 255, 255, .08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .025);
  box-shadow: none;
}

.memory-textarea {
  min-height: 180rpx;
  margin: 0;
  padding: 24rpx 24rpx 64rpx;
  border: 0;
  border-radius: 16rpx;
  background: transparent;
  box-shadow: none;
  font-family: "Songti SC", STSong, serif;
  font-size: 29rpx;
  line-height: 1.65;
}

.count-row {
  position: absolute;
  right: 24rpx;
  bottom: 20rpx;
  color: rgba(164, 175, 189, .68);
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-size: 23rpx;
  text-align: right;
}

.mode-cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin: 4rpx 0 30rpx;
}

.mode-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 28rpx 22rpx;
  border: 1px solid rgba(255, 255, 255, .08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .015);
  box-shadow: none;
}

.mode-card-active {
  border-color: rgba(197, 164, 94, .5);
  background: rgba(197, 164, 94, .05);
  box-shadow: none;
}

.mode-radio {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
}

.mode-indicator {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border: 1px solid rgba(255, 255, 255, .26);
  border-radius: 50%;
  color: transparent;
  font-size: 0;
  font-weight: 800;
}

.mode-card-active .mode-indicator {
  border-color: rgba(197, 164, 94, .76);
  background: transparent;
}

.mode-card-active .mode-indicator::after {
  content: "";
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #C5A45E;
}

.mode-title {
  color: #EDF1F5;
  font-size: 32rpx;
  font-weight: 700;
}

.mode-desc {
  margin-top: 6rpx;
  color: #A4AFBD;
  font-size: 26rpx;
  line-height: 1.5;
}

.brand-disclosure-card {
  margin: 0 0 30rpx;
  padding: 20rpx;
  border: 1px solid rgba(255, 255, 255, .08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .02);
}

.brand-preview-text {
  margin-bottom: 16rpx;
  color: #A4AFBD;
  font-size: 24rpx;
  line-height: 1.55;
}

.brand-toggle-row {
  display: flex;
  align-items: center;
  color: #EDF1F5;
  font-size: 26rpx;
}

.brand-checkbox {
  transform: scale(.82);
}

.brand-label {
  margin-left: 12rpx;
  color: rgba(237, 241, 245, .86);
}

.record-submit {
  height: 96rpx;
  min-height: 96rpx;
  margin-top: 4rpx;
  border-radius: 14rpx;
  background: #C5A45E;
  color: #050B14;
  box-shadow: none;
}

.record-submit::after,
.btn-submit::after {
  border: none;
}

.record-submit-active {
  background: #AD8C4D;
}

.record-footnote {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, .48);
  font-size: 23rpx;
  line-height: 1.6;
  text-align: center;
}

.record-message {
  min-height: 40rpx;
  margin-top: 18rpx;
  text-align: center;
}
