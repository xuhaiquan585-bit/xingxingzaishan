.record-page {
  position: relative;
  overflow: hidden;
  padding: 52rpx 28rpx 84rpx;
  background:
    radial-gradient(circle at 20% 4%, rgba(255, 221, 150, .18), transparent 28%),
    radial-gradient(circle at 90% 18%, rgba(118, 151, 255, .18), transparent 28%),
    linear-gradient(168deg, #081341 0%, #152158 52%, #26346a 100%);
}

.record-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.record-glow-top {
  top: -120rpx;
  right: -140rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(255, 209, 102, .12);
}

.record-glow-bottom {
  left: -160rpx;
  bottom: 160rpx;
  width: 420rpx;
  height: 420rpx;
  background: rgba(97, 132, 255, .12);
}

.record-hero,
.record-card {
  position: relative;
  z-index: 1;
}

.record-hero {
  padding: 16rpx 4rpx 30rpx;
}

.record-brand {
  margin-bottom: 18rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 24rpx;
  letter-spacing: 0;
}

.record-title {
  margin-bottom: 14rpx;
  font-size: 50rpx;
  line-height: 1.18;
}

.record-subtitle {
  max-width: 650rpx;
  margin-bottom: 24rpx;
  color: rgba(255, 255, 255, .84);
  font-size: 27rpx;
  line-height: 1.72;
}

.trust-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.trust-tag {
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(255, 227, 155, .34);
  border-radius: 999rpx;
  background: rgba(255, 227, 155, .1);
  color: #ffe39b;
  font-size: 23rpx;
}

.record-card {
  padding: 30rpx;
  border-color: rgba(255, 255, 255, .2);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .11);
  box-shadow: 0 28rpx 72rpx rgba(4, 10, 38, .28);
}

.record-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 24rpx;
}

.record-meta-label {
  color: rgba(255, 255, 255, .58);
}

.record-meta-value {
  color: rgba(255, 255, 255, .9);
  font-weight: 600;
}

.photo-frame {
  box-sizing: border-box;
  width: 100%;
  min-height: 360rpx;
  margin: 0 0 30rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 227, 155, .28);
  border-radius: 26rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, .13), rgba(255, 255, 255, .06)),
    rgba(5, 10, 34, .2);
  color: #fff;
  line-height: 1.4;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .14);
}

.photo-frame::after {
  border: 0;
}

.photo-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
  border: 1rpx dashed rgba(255, 227, 155, .34);
  border-radius: 22rpx;
  background: rgba(7, 14, 46, .22);
}

.photo-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  margin-bottom: 22rpx;
  border-radius: 50%;
  background: rgba(255, 209, 102, .18);
  color: #ffd166;
  font-size: 52rpx;
  line-height: 1;
}

.photo-title {
  color: #fff;
  font-size: 31rpx;
  font-weight: 700;
}

.photo-hint {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .58);
  font-size: 23rpx;
}

.photo-action {
  margin-top: 18rpx;
  color: #ffe39b;
  font-size: 25rpx;
  font-weight: 700;
}

.preview {
  display: block;
  margin: 0;
}

.field-block {
  margin-bottom: 28rpx;
}

.field-title {
  margin-bottom: 14rpx;
  color: #ffe39b;
  font-size: 28rpx;
  font-weight: 700;
}

.memory-textarea {
  min-height: 230rpx;
  margin: 0;
  padding: 26rpx;
  border-color: rgba(255, 255, 255, .16);
  border-radius: 22rpx;
  background: rgba(6, 12, 42, .38);
  font-size: 29rpx;
  line-height: 1.65;
}

.count-row {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .54);
  font-size: 23rpx;
  text-align: right;
}

.mode-cards {
  display: grid;
  gap: 18rpx;
  margin: 4rpx 0 30rpx;
}

.mode-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, .16);
  border-radius: 22rpx;
  background: rgba(7, 14, 46, .24);
}

.mode-card-active {
  border-color: rgba(255, 209, 102, .72);
  background: rgba(255, 209, 102, .13);
  box-shadow: 0 14rpx 34rpx rgba(255, 209, 102, .08);
}

.mode-radio {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
}

.mode-indicator {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border: 1rpx solid rgba(255, 255, 255, .28);
  border-radius: 50%;
  color: #141414;
  font-size: 24rpx;
  font-weight: 800;
}

.mode-card-active .mode-indicator {
  border-color: #ffd166;
  background: #ffd166;
}

.mode-title {
  color: #fff;
  font-size: 29rpx;
  font-weight: 700;
}

.mode-desc {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, .62);
  font-size: 23rpx;
  line-height: 1.5;
}

.record-submit {
  min-height: 96rpx;
  margin-top: 0;
  box-shadow: 0 18rpx 42rpx rgba(255, 209, 102, .2);
}

.record-message {
  min-height: 40rpx;
  margin-top: 18rpx;
  text-align: center;
}
