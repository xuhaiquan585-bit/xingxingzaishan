.record-page {
  position: relative;
  overflow: hidden;
  padding: 58rpx 28rpx 88rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 221, 150, .08), transparent 28%),
    radial-gradient(circle at 92% 14%, rgba(118, 151, 255, .12), transparent 30%),
    linear-gradient(170deg, #07123a 0%, #121f55 54%, #223167 100%);
}

.record-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.record-glow-top {
  top: -150rpx;
  right: -180rpx;
  width: 340rpx;
  height: 340rpx;
  background: rgba(255, 209, 102, .06);
}

.record-glow-bottom {
  left: -160rpx;
  bottom: 160rpx;
  width: 420rpx;
  height: 420rpx;
  background: rgba(97, 132, 255, .08);
}

.record-hero,
.record-card {
  position: relative;
  z-index: 1;
}

.record-hero {
  padding: 18rpx 4rpx 38rpx;
}

.record-title {
  max-width: 620rpx;
  margin-bottom: 18rpx;
  font-size: 52rpx;
  line-height: 1.24;
  font-weight: 800;
}

.trust-line {
  margin-bottom: 20rpx;
  color: rgba(255, 227, 155, .78);
  font-size: 23rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.record-subtitle {
  max-width: 600rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 27rpx;
  line-height: 1.7;
}

.record-card {
  padding: 26rpx;
  border-color: rgba(255, 255, 255, .13);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .075);
  box-shadow: 0 24rpx 58rpx rgba(4, 10, 38, .2);
}

.record-meta-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  margin-bottom: 16rpx;
  color: rgba(255, 255, 255, .48);
  font-size: 20rpx;
}

.record-meta-label {
  color: rgba(255, 255, 255, .38);
}

.record-meta-value {
  color: rgba(255, 255, 255, .66);
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-weight: 600;
  letter-spacing: 0;
}

.photo-frame {
  box-sizing: border-box;
  width: 100%;
  min-height: 410rpx;
  margin: 0 0 34rpx;
  padding: 0;
  border: 0;
  border-radius: 28rpx;
  background: transparent;
  color: #fff;
  line-height: 1.4;
  box-shadow: none;
}

.photo-frame::after {
  border: 0;
}

.photo-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 408rpx;
  border: 1rpx dashed rgba(255, 227, 155, .3);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .035);
}

.photo-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  margin-bottom: 22rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, .06);
  color: #ffd166;
  font-size: 48rpx;
  line-height: 1;
}

.photo-title {
  color: #fff;
  font-size: 31rpx;
  font-weight: 700;
}

.photo-hint {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .5);
  font-size: 23rpx;
}

.photo-action {
  margin-top: 18rpx;
  color: #ffe39b;
  font-size: 25rpx;
  font-weight: 700;
}

.preview {
  display: block;
  margin: 0;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, .035);
}

.field-block {
  margin-bottom: 26rpx;
}

.field-title {
  margin-bottom: 14rpx;
  color: rgba(255, 255, 255, .86);
  font-size: 28rpx;
  font-weight: 700;
}

.memory-textarea {
  min-height: 230rpx;
  margin: 0;
  padding: 26rpx;
  border-color: rgba(255, 255, 255, .12);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .055);
  font-size: 29rpx;
  line-height: 1.65;
}

.count-row {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .54);
  font-size: 23rpx;
  text-align: right;
}

.mode-cards {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin: 4rpx 0 30rpx;
}

.mode-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  min-height: 118rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, .12);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .045);
}

.mode-card-active {
  border-color: rgba(255, 209, 102, .58);
  background: rgba(255, 209, 102, .095);
  box-shadow: none;
}

.mode-radio {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
}

.mode-indicator {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border: 1rpx solid rgba(255, 255, 255, .28);
  border-radius: 50%;
  color: #141414;
  font-size: 21rpx;
  font-weight: 800;
}

.mode-card-active .mode-indicator {
  border-color: #ffd166;
  background: #ffd166;
}

.mode-title {
  color: #fff;
  font-size: 27rpx;
  font-weight: 700;
}

.mode-desc {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, .56);
  font-size: 21rpx;
  line-height: 1.5;
}

.brand-disclosure-card {
  margin: 0 0 30rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, .12);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .045);
}

.brand-preview-text {
  margin-bottom: 16rpx;
  color: rgba(255, 255, 255, .64);
  font-size: 24rpx;
  line-height: 1.55;
}

.brand-toggle-row {
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 26rpx;
}

.brand-checkbox {
  transform: scale(.82);
}

.brand-label {
  margin-left: 12rpx;
  color: rgba(255, 255, 255, .88);
}

.record-submit {
  min-height: 96rpx;
  margin-top: 4rpx;
  box-shadow: 0 16rpx 36rpx rgba(255, 209, 102, .18);
}

.record-message {
  min-height: 40rpx;
  margin-top: 18rpx;
  text-align: center;
}
