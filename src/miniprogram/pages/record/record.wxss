page {
  background: #C9D8E6;
  color: #263445;
}

.record-page {
  position: relative;
  overflow: hidden;
  padding: 58rpx 28rpx 160rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(
      circle at 88% 8%,
      rgba(244, 194, 142, .22),
      transparent 30%
    ),
    linear-gradient(
      180deg,
      #C9D8E6 0%,
      #E2E9ED 42%,
      #F0EEE8 100%
    );
  color: #263445;
}

.record-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.record-glow-top {
  top: -150rpx;
  right: -180rpx;
  width: 340rpx;
  height: 340rpx;
  background: transparent;
}

.record-glow-bottom {
  left: 50%;
  bottom: 70rpx;
  width: 520rpx;
  height: 300rpx;
  background: transparent;
  transform: translateX(-50%);
}

.record-hero,
.record-card {
  position: relative;
  z-index: 1;
}

.record-hero {
  padding: 18rpx 4rpx 40rpx;
}

.record-title {
  max-width: 600rpx;
  margin-bottom: 14rpx;
  color: #263445;
  font-size: 46rpx;
  line-height: 1.32;
  font-weight: 700;
  letter-spacing: 0;
}

.trust-line {
  margin-top: 16rpx;
  color: #9F763B;
  font-size: 23rpx;
  font-weight: 600;
  letter-spacing: .5rpx;
}

.record-subtitle {
  max-width: 600rpx;
  color: #647487;
  font-size: 28rpx;
  line-height: 1.62;
}

.record-card {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.record-card,
.photo-empty,
.textarea-shell,
.mode-card,
.brand-disclosure-card {
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}

.record-meta-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 10rpx;
  margin-bottom: 18rpx;
  color: #8491A0;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-size: 22rpx;
}

.record-meta-label {
  color: #8491A0;
}

.record-meta-value {
  color: #263445;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-weight: 600;
  letter-spacing: 0;
}

.photo-frame {
  box-sizing: border-box;
  width: 100%;
  min-height: 280rpx;
  margin: 0 0 34rpx;
  padding: 0;
  border: 0;
  border-radius: 20rpx;
  background: transparent;
  color: #263445;
  line-height: 1.4;
  box-shadow: none;
}

.photo-frame::after {
  border: 0;
}

.photo-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 280rpx;
  border: 1px dashed rgba(181, 139, 74, .40);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .68);
  box-shadow: 0 10rpx 30rpx rgba(66, 79, 91, .08);
}

.photo-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  margin-bottom: 22rpx;
  border-radius: 14rpx;
  background: transparent;
  color: #B68B49;
  font-size: 48rpx;
  line-height: 1;
}

.photo-title {
  color: #263445;
  font-size: 31rpx;
  font-weight: 700;
}

.photo-hint {
  margin-top: 10rpx;
  color: #8491A0;
  font-size: 23rpx;
}

.photo-action {
  margin-top: 18rpx;
  color: #B68B49;
  font-size: 25rpx;
  font-weight: 700;
}

.preview {
  display: block;
  margin: 0;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .72);
  box-shadow: 0 10rpx 30rpx rgba(66, 79, 91, .08);
}

.field-block {
  margin-bottom: 26rpx;
}

.field-title {
  margin-bottom: 14rpx;
  color: #263445;
  font-size: 32rpx;
  font-weight: 700;
}

.textarea-shell {
  position: relative;
  border: 1px solid rgba(52, 72, 91, .12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .62);
  box-shadow: none;
}

.textarea-shell:focus-within {
  border-color: rgba(181, 139, 74, .50);
}

.memory-textarea {
  min-height: 180rpx;
  margin: 0;
  padding: 24rpx 24rpx 64rpx;
  border: 0;
  border-radius: 16rpx;
  background: transparent;
  box-shadow: none;
  color: #263445;
  font-family: "Songti SC", STSong, serif;
  font-size: 29rpx;
  line-height: 1.65;
}

.memory-placeholder {
  color: #8A96A3;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.count-row {
  position: absolute;
  right: 24rpx;
  bottom: 20rpx;
  color: #7B8998;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-size: 23rpx;
  text-align: right;
}

.mode-cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin: 4rpx 0 30rpx;
}

.mode-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 28rpx 22rpx;
  border: 1px solid rgba(52, 72, 91, .12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .50);
  box-shadow: none;
}

.mode-card-active {
  border-color: rgba(181, 139, 74, .50);
  background: rgba(201, 166, 100, .13);
  box-shadow: none;
}

.mode-radio {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
}

.mode-indicator {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border: 1px solid rgba(52, 72, 91, .22);
  border-radius: 50%;
  color: transparent;
  font-size: 0;
  font-weight: 800;
}

.mode-card-active .mode-indicator {
  border-color: #B68B49;
  background: transparent;
}

.mode-card-active .mode-indicator::after {
  content: "";
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #B68B49;
}

.mode-title {
  color: #263445;
  font-size: 32rpx;
  font-weight: 700;
}

.mode-desc {
  margin-top: 6rpx;
  color: #647487;
  font-size: 26rpx;
  line-height: 1.5;
}

.brand-disclosure-card {
  margin: 0 0 30rpx;
  padding: 20rpx;
  border: 1px solid rgba(52, 72, 91, .12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .46);
}

.brand-preview-text {
  margin-bottom: 16rpx;
  color: #647487;
  font-size: 24rpx;
  line-height: 1.55;
}

.brand-toggle-row {
  display: flex;
  align-items: center;
  color: #263445;
  font-size: 26rpx;
}

.brand-checkbox {
  transform: scale(.82);
}

.brand-label {
  margin-left: 12rpx;
  color: #263445;
}

.record-submit {
  height: 96rpx;
  min-height: 96rpx;
  margin-top: 4rpx;
  border-radius: 14rpx;
  background: #B68B49;
  color: #182431;
  box-shadow: none;
}

.record-submit::after,
.btn-submit::after {
  border: none;
}

.record-submit-active {
  background: #9F763B;
}

.record-footnote {
  margin-top: 18rpx;
  color: #738295;
  font-size: 23rpx;
  line-height: 1.6;
  text-align: center;
}

.record-message {
  min-height: 40rpx;
  margin-top: 18rpx;
  color: #A45F58;
  text-align: center;
}
