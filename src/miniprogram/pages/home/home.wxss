.home-page {
  padding-top: 36rpx;
}

.home-hero,
.home-carousel,
.home-section {
  position: relative;
  z-index: 1;
}

.home-hero {
  padding: 14rpx 0 18rpx;
}

.home-brand-wrap {
  width: 132rpx;
  height: 132rpx;
  margin-bottom: 30rpx;
}

.home-logo,
.home-brand-mark {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
}

.home-logo {
  display: block;
  border: 1rpx solid rgba(212, 175, 55, .22);
  background: rgba(255, 255, 255, .04);
  box-shadow: 0 20rpx 48rpx rgba(4, 10, 38, .2), inset 0 1rpx 0 rgba(255, 255, 255, .06);
}

.home-brand-mark {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(212, 175, 55, .22);
  background:
    radial-gradient(circle at 50% 44%, rgba(212, 175, 55, .18), transparent 52%),
    rgba(255, 255, 255, .035);
  box-shadow: 0 20rpx 48rpx rgba(4, 10, 38, .2), inset 0 1rpx 0 rgba(255, 255, 255, .06);
}

.home-brand-star {
  color: #e4c46e;
  font-size: 78rpx;
  line-height: 1;
  text-shadow: 0 0 24rpx rgba(212, 175, 55, .16);
}

.home-brand-vessel {
  position: absolute;
  top: 42rpx;
  left: 50%;
  width: 14rpx;
  height: 52rpx;
  border-radius: 8rpx 8rpx 10rpx 10rpx;
  background: rgba(7, 18, 58, .72);
  transform: translateX(-50%);
}

.home-kicker {
  margin-bottom: 16rpx;
  color: rgba(228, 196, 110, .78);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.home-page .hero-title {
  max-width: 620rpx;
  font-size: 50rpx;
  line-height: 1.22;
}

.home-page .subtitle {
  max-width: 640rpx;
  margin-bottom: 0;
}

.home-carousel {
  height: 500rpx;
  margin: 22rpx 0 30rpx;
  overflow: hidden;
  border-radius: 28rpx;
}

.home-slide {
  position: relative;
  height: 100%;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, .09);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .04);
  box-sizing: border-box;
  box-shadow: 0 26rpx 58rpx rgba(3, 8, 32, .26), inset 0 1rpx 0 rgba(255, 255, 255, .08);
}

.home-slide-image,
.home-slide-fallback,
.home-slide-overlay {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.home-slide-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 74% 24%, rgba(212, 175, 55, .2), transparent 34%),
    radial-gradient(circle at 20% 80%, rgba(110, 139, 224, .22), transparent 36%),
    rgba(255, 255, 255, .035);
}

.home-slide-symbol {
  color: rgba(228, 196, 110, .8);
  font-size: 126rpx;
  text-shadow: 0 0 40rpx rgba(212, 175, 55, .18);
}

.home-slide-overlay {
  background:
    linear-gradient(180deg, rgba(8, 16, 55, .08), rgba(8, 16, 55, .78)),
    linear-gradient(90deg, rgba(8, 16, 55, .78), rgba(8, 16, 55, .12));
}

.home-slide-copy {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 34rpx;
}

.home-slide-title {
  color: #ffe6a3;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.26;
}

.home-slide-subtitle {
  max-width: 560rpx;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, .78);
  font-size: 25rpx;
  line-height: 1.5;
}

.home-slide-btn {
  width: 240rpx;
  min-height: 72rpx;
  margin: 24rpx 0 0;
  font-size: 26rpx;
}

.home-section {
  margin-bottom: 30rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, .075);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .038);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .06);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.home-section-eyebrow {
  display: inline-flex;
  margin-bottom: 16rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(212, 175, 55, .26);
  border-radius: 999rpx;
  color: rgba(228, 196, 110, .82);
  font-size: 22rpx;
  font-weight: 700;
}

.home-section-title {
  margin-bottom: 18rpx;
  color: #e4c46e;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.36;
}

.home-commerce-section .hint {
  margin-bottom: 28rpx;
  color: rgba(255, 255, 255, .72);
}

.home-primary-cta {
  min-height: 98rpx;
  margin-top: 0;
  font-size: 31rpx;
}

.home-scan-link {
  width: 390rpx;
  min-height: 74rpx;
  margin: 18rpx auto 0;
  font-size: 26rpx;
  font-weight: 600;
}

.home-scene-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.home-scene-card {
  display: grid;
  grid-template-columns: 190rpx minmax(0, 1fr);
  gap: 22rpx;
  align-items: stretch;
  min-height: 178rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .032);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .05);
}

.home-scene-image,
.home-scene-fallback {
  width: 190rpx;
  height: 178rpx;
  border-radius: 18rpx;
}

.home-scene-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 50% 38%, rgba(212, 175, 55, .18), transparent 50%),
    rgba(255, 255, 255, .04);
}

.home-scene-symbol {
  color: rgba(228, 196, 110, .78);
  font-size: 58rpx;
}

.home-scene-copy {
  min-width: 0;
}

.home-scene-label {
  color: rgba(228, 196, 110, .68);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.home-scene-title {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, .92);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.34;
}

.home-scene-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, .64);
  font-size: 24rpx;
  line-height: 1.48;
}

.home-scene-action {
  margin-top: 14rpx;
  color: rgba(228, 196, 110, .82);
  font-size: 23rpx;
  font-weight: 700;
}

.home-trust-section {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 0;
  border: 0;
  background: transparent;
  box-shadow: none;
}

.home-trust-item {
  padding: 12rpx 20rpx;
  border: 1rpx solid rgba(212, 175, 55, .18);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .028);
  color: rgba(228, 196, 110, .76);
  font-size: 23rpx;
}
