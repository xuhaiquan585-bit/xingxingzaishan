.home-page {
  padding-top: 44rpx;
}

.home-hero {
  position: relative;
  z-index: 1;
  padding: 16rpx 0 8rpx;
}

.home-brand-mark {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 34rpx;
  border: 1rpx solid rgba(212, 175, 55, .22);
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 44%, rgba(212, 175, 55, .18), transparent 52%),
    rgba(255, 255, 255, .035);
  box-shadow: 0 20rpx 48rpx rgba(4, 10, 38, .2), inset 0 1rpx 0 rgba(255, 255, 255, .06);
}

.home-brand-star {
  color: #e4c46e;
  font-size: 82rpx;
  line-height: 1;
  text-shadow: 0 0 24rpx rgba(212, 175, 55, .16);
}

.home-brand-vessel {
  position: absolute;
  top: 44rpx;
  left: 50%;
  width: 14rpx;
  height: 54rpx;
  border-radius: 8rpx 8rpx 10rpx 10rpx;
  background: rgba(7, 18, 58, .7);
  transform: translateX(-50%);
}

.home-kicker {
  margin-bottom: 18rpx;
  color: rgba(228, 196, 110, .78);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.home-page .hero-title {
  font-size: 50rpx;
}

.home-page .subtitle {
  margin-bottom: 32rpx;
}

.home-section,
.home-secondary-actions {
  position: relative;
  z-index: 1;
}

.home-primary-cta {
  min-height: 104rpx;
  margin-top: 0;
  font-size: 32rpx;
}

.home-buy-cta {
  min-height: 88rpx;
  margin-top: 18rpx;
  background: rgba(212, 175, 55, .12);
  color: #ffe7a3;
  border: 1rpx solid rgba(212, 175, 55, .42);
}

.home-scan-link {
  width: 360rpx;
  min-height: 72rpx;
  margin-top: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.home-section {
  margin-bottom: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, .075);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .032);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .05);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.home-section-title {
  margin-bottom: 20rpx;
  color: #e4c46e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.36;
}

.home-scene-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.home-scene-item,
.home-trust-item {
  border: 1rpx solid rgba(255, 255, 255, .1);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .035);
  color: rgba(255, 255, 255, .78);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .05);
}

.home-scene-item {
  min-height: 156rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.home-scene-label {
  color: #e4c46e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.home-scene-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, .62);
  font-size: 23rpx;
  line-height: 1.55;
}

.home-commerce-actions,
.home-secondary-actions {
  display: flex;
  gap: 18rpx;
}

.home-entry-btn {
  flex: 1;
  min-height: 78rpx;
  margin: 0;
  font-size: 27rpx;
  font-weight: 600;
}

.home-trust-section {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.home-trust-item {
  padding: 12rpx 20rpx;
  color: rgba(228, 196, 110, .76);
  font-size: 23rpx;
}

.home-secondary-actions {
  margin-bottom: 10rpx;
}

.home-banner {
  width: 100%;
  height: 390rpx;
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 20rpx;
  margin: 24rpx 0 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(3, 8, 32, .24);
}
