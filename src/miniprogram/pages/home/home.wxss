.home-page {
  min-height: 100vh;
  padding-top: 42rpx;
  padding-bottom: calc(128rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 50% 0%, #0b152d 0%, #020a14 100%);
}

.home-page::before {
  content: "";
  position: absolute;
  top: 36rpx;
  left: 50%;
  width: 520rpx;
  height: 520rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 42%, rgba(212, 175, 55, .16), transparent 52%),
    radial-gradient(circle at 54% 50%, rgba(126, 155, 255, .12), transparent 64%);
  transform: translateX(-50%);
  animation: star-pulse 5.8s ease-in-out infinite;
  pointer-events: none;
}

.home-page::after {
  content: "";
  position: absolute;
  top: 18rpx;
  left: 0;
  right: 0;
  height: 520rpx;
  background:
    radial-gradient(circle at 20% 24%, rgba(255, 255, 255, .18) 0, rgba(255, 255, 255, .18) 1rpx, transparent 2rpx),
    radial-gradient(circle at 72% 16%, rgba(228, 196, 110, .2) 0, rgba(228, 196, 110, .2) 1rpx, transparent 2rpx),
    radial-gradient(circle at 84% 42%, rgba(255, 255, 255, .14) 0, rgba(255, 255, 255, .14) 1rpx, transparent 2rpx);
  animation: star-pulse 4.8s ease-in-out infinite;
  pointer-events: none;
}

@keyframes star-pulse {
  0%,
  100% {
    opacity: .3;
  }

  50% {
    opacity: .8;
  }
}

.home-hero,
.home-carousel,
.home-section {
  position: relative;
  z-index: 1;
}

.home-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 26rpx 0 34rpx;
  text-align: center;
}

.home-brand-wrap {
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 26rpx;
}

.home-logo,
.home-brand-mark {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.home-logo {
  display: block;
  border: 1rpx solid rgba(212, 175, 55, .3);
  background: rgba(255, 255, 255, .03);
  box-shadow: 0 0 34rpx rgba(212, 175, 55, .16), inset 0 1rpx 0 rgba(255, 255, 255, .08);
}

.home-brand-mark {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(212, 175, 55, .3);
  background: rgba(255, 255, 255, .03);
  box-shadow: 0 0 34rpx rgba(212, 175, 55, .16), inset 0 1rpx 0 rgba(255, 255, 255, .08);
}

.home-brand-star {
  color: #e4c46e;
  font-size: 62rpx;
  line-height: 1;
  text-shadow: 0 0 24rpx rgba(212, 175, 55, .24);
}

.home-brand-vessel {
  position: absolute;
  top: 34rpx;
  left: 50%;
  width: 12rpx;
  height: 42rpx;
  border-radius: 8rpx;
  background: rgba(2, 10, 20, .76);
  transform: translateX(-50%);
}

.home-page .hero-title {
  max-width: 660rpx;
  margin-bottom: 20rpx;
  color: #f3d77b;
  font-family: "Songti SC", STSong, serif;
  font-size: 58rpx;
  font-weight: 700;
  line-height: 1.22;
  text-align: center;
  text-shadow: 0 0 28rpx rgba(212, 175, 55, .14);
}

.home-page .subtitle {
  max-width: 640rpx;
  margin-bottom: 0;
  color: rgba(255, 255, 255, .74);
  font-size: 27rpx;
  line-height: 1.68;
  text-align: center;
}

.home-carousel {
  height: 640rpx;
  margin: 18rpx -32rpx 34rpx;
  overflow: hidden;
}

.home-slide {
  position: relative;
  height: 100%;
  margin: 0 10rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .03);
  box-sizing: border-box;
  box-shadow: 0 32rpx 70rpx rgba(2, 8, 24, .34), inset 0 1rpx 0 rgba(255, 255, 255, .08);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
}

.home-slide-image,
.home-slide-fallback,
.home-slide-overlay {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.home-slide-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 68% 22%, rgba(212, 175, 55, .18), transparent 38%),
    radial-gradient(circle at 22% 82%, rgba(126, 155, 255, .16), transparent 40%),
    rgba(255, 255, 255, .03);
}

.home-slide-symbol {
  color: rgba(228, 196, 110, .78);
  font-size: 138rpx;
  text-shadow: 0 0 42rpx rgba(212, 175, 55, .18);
}

.home-slide-overlay {
  background:
    linear-gradient(180deg, rgba(2, 10, 20, .08), rgba(2, 10, 20, .84)),
    linear-gradient(90deg, rgba(2, 10, 20, .76), rgba(2, 10, 20, .14));
}

.home-slide-copy {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 38rpx;
}

.home-slide-title {
  color: #ffe6a3;
  font-family: "Songti SC", STSong, serif;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.28;
}

.home-slide-subtitle {
  max-width: 560rpx;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, .78);
  font-size: 25rpx;
  line-height: 1.56;
}

.home-slide-btn {
  width: 240rpx;
  min-height: 76rpx;
  margin: 28rpx 0 0;
  border: 1rpx solid rgba(212, 175, 55, .45);
  background: rgba(255, 255, 255, .1);
  color: #ffe6a3;
  font-size: 26rpx;
  box-shadow: 0 0 20rpx rgba(212, 175, 55, .26), inset 0 1rpx 0 rgba(255, 255, 255, .1);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
}

.home-section {
  margin-bottom: 30rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .03);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .06);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
}

.home-section-eyebrow {
  display: inline-flex;
  margin-bottom: 16rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(212, 175, 55, .26);
  border-radius: 999rpx;
  color: rgba(228, 196, 110, .82);
  font-size: 22rpx;
  font-weight: 700;
}

.home-section-title {
  margin-bottom: 18rpx;
  color: #e4c46e;
  font-family: "Songti SC", STSong, serif;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.36;
}

.home-commerce-section .hint {
  margin-bottom: 28rpx;
  color: rgba(255, 255, 255, .72);
}

.home-primary-cta {
  min-height: 96rpx;
  margin-top: 0;
  border: 1rpx solid rgba(212, 175, 55, .56);
  background: rgba(255, 255, 255, .055);
  color: #ffe6a3;
  font-size: 31rpx;
  box-shadow: 0 0 20rpx rgba(212, 175, 55, .3), inset 0 1rpx 0 rgba(255, 255, 255, .08);
}

.home-scan-link {
  width: 390rpx;
  min-height: 74rpx;
  margin: 18rpx auto 0;
  font-size: 26rpx;
  font-weight: 600;
}

.home-scene-section {
  padding-right: 0;
}

.home-scene-scroll {
  width: 100%;
  white-space: nowrap;
}

.home-scene-list {
  display: flex;
  gap: 24rpx;
  padding-right: 30rpx;
}

.home-scene-card {
  display: inline-flex;
  flex: 0 0 480rpx;
  width: 480rpx;
  min-height: 420rpx;
  flex-direction: column;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .03);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .06);
  white-space: normal;
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
}

.home-scene-image,
.home-scene-fallback {
  width: 480rpx;
  height: 230rpx;
}

.home-scene-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 50% 38%, rgba(212, 175, 55, .18), transparent 50%),
    rgba(255, 255, 255, .035);
}

.home-scene-symbol {
  color: rgba(228, 196, 110, .78);
  font-size: 72rpx;
}

.home-scene-copy {
  min-width: 0;
  padding: 24rpx;
}

.home-scene-label {
  color: rgba(228, 196, 110, .68);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.home-scene-title {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .92);
  font-family: "Songti SC", STSong, serif;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.34;
}

.home-scene-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .64);
  font-size: 24rpx;
  line-height: 1.5;
}

.home-scene-action {
  margin-top: 16rpx;
  color: rgba(228, 196, 110, .82);
  font-size: 23rpx;
  font-weight: 700;
}

.home-trust-section {
  padding: 32rpx 24rpx 34rpx;
  text-align: center;
}

.home-trust-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.home-trust-item {
  padding: 10rpx 4rpx 0;
}

.home-trust-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 12rpx;
  border: 1rpx solid rgba(212, 175, 55, .24);
  border-radius: 50%;
  background: rgba(255, 255, 255, .035);
  color: #e4c46e;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 0 20rpx rgba(212, 175, 55, .12);
}

.home-trust-label {
  color: rgba(255, 255, 255, .72);
  font-size: 22rpx;
  line-height: 1.35;
}

.home-trust-copy {
  margin-top: 26rpx;
  color: rgba(228, 196, 110, .72);
  font-size: 24rpx;
  line-height: 1.58;
}
