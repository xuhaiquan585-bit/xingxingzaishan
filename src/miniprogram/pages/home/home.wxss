.home-page {
  padding-top: 44rpx;
}

.home-hero {
  position: relative;
  z-index: 1;
  padding: 16rpx 0 8rpx;
}

.home-brand-mark {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 34rpx;
  border: 1rpx solid rgba(212, 175, 55, .22);
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 44%, rgba(212, 175, 55, .18), transparent 52%),
    rgba(255, 255, 255, .035);
  box-shadow: 0 20rpx 48rpx rgba(4, 10, 38, .2), inset 0 1rpx 0 rgba(255, 255, 255, .06);
}

.home-brand-star {
  color: #e4c46e;
  font-size: 82rpx;
  line-height: 1;
  text-shadow: 0 0 24rpx rgba(212, 175, 55, .16);
}

.home-brand-vessel {
  position: absolute;
  top: 44rpx;
  left: 50%;
  width: 14rpx;
  height: 54rpx;
  border-radius: 8rpx 8rpx 10rpx 10rpx;
  background: rgba(7, 18, 58, .7);
  transform: translateX(-50%);
}

.home-page .hero-title {
  font-size: 50rpx;
}

.home-page .subtitle {
  margin-bottom: 28rpx;
}

.home-panel {
  padding: 32rpx;
  border-color: rgba(255, 255, 255, .075);
}

.home-panel-copy {
  margin-bottom: 30rpx;
}

.home-panel .hint {
  margin-top: 16rpx;
  margin-bottom: 0;
  color: rgba(255, 255, 255, .68);
}

.home-scan-btn {
  min-height: 104rpx;
  margin-top: 0;
  font-size: 32rpx;
}

.home-entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.home-entry-btn {
  min-height: 78rpx;
  margin: 0;
  font-size: 27rpx;
  font-weight: 600;
}

.home-banner {
  width: 100%;
  height: 390rpx;
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 20rpx;
  margin: 24rpx 0 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(3, 8, 32, .24);
}
