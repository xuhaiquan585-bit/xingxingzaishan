<view class="page">
  <view class="hero-title">{{content.home_title}}</view>
  <view class="subtitle">{{content.home_subtitle}}</view>
  <image wx:if="{{hasBanner}}" class="home-banner" mode="aspectFill" src="{{bannerImage}}" />

  <view class="card">
    <view class="list-title">{{content.project_title}}</view>
    <view class="hint">{{content.project_body}}</view>
    <button class="btn" bindtap="scanCode">扫码记录</button>
    <button class="btn secondary" bindtap="goProject">项目说明</button>
    <button class="btn secondary" bindtap="goProducts">查看商品</button>
    <button wx:if="{{hasConsultUrl}}" class="btn secondary" bindtap="copyConsultLink">{{content.consult_label}}</button>
    <button class="btn secondary" bindtap="goMe">我的记录</button>
  </view>
</view>
