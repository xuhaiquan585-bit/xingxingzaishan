<view class="page home-page">
  <view class="home-hero">
    <view class="home-brand-mark">
      <view class="home-brand-star">✦</view>
      <view class="home-brand-vessel"></view>
    </view>
    <view class="home-kicker">一瓶酒 · 一张照片 · 一句话</view>
    <view class="hero-title">{{content.home_title}}</view>
    <view class="subtitle">{{content.home_subtitle}}</view>
    <button class="btn home-primary-cta" bindtap="focusScenes">封存这一刻</button>
    <button class="btn secondary home-scan-link" bindtap="scanCode">已有酒瓶，扫码记录</button>
  </view>

  <image wx:if="{{hasBanner}}" class="home-banner" mode="aspectFill" src="{{bannerImage}}" />

  <view class="home-section home-scene-section">
    <view class="home-section-title">你想把这份心意留给谁？</view>
    <view class="home-scene-grid">
      <view
        wx:for="{{sceneOptions}}"
        wx:key="key"
        class="home-scene-item"
        bindtap="goSceneProducts"
        data-scene="{{item.key}}"
      >
        <view class="home-scene-label">{{item.label}}</view>
        <view class="home-scene-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="home-section home-commerce-section">
    <view class="home-section-title">选择一份能被记住的酒</view>
    <view class="hint">{{content.project_body}}</view>
    <view class="home-commerce-actions">
      <button class="btn secondary home-entry-btn" bindtap="goProducts">查看全部</button>
      <button wx:if="{{hasConsultUrl}}" class="btn secondary home-entry-btn" bindtap="copyConsultLink">{{content.consult_label}}</button>
    </view>
  </view>

  <view class="home-section home-trust-section">
    <view class="home-trust-item">区块链存证</view>
    <view class="home-trust-item">链上存证</view>
    <view class="home-trust-item">封存后可查看</view>
  </view>

  <view class="home-secondary-actions">
    <button class="btn secondary home-entry-btn" bindtap="goProject">关于</button>
    <button class="btn secondary home-entry-btn" bindtap="goMe">我的星星</button>
  </view>
</view>
