.project-hero {
  position: relative;
  z-index: 1;
  padding: 10rpx 0 6rpx;
}

.project-page .hero-title {
  font-size: 48rpx;
}

.project-text {
  white-space: pre-wrap;
  color: rgba(255, 255, 255, .82);
  font-size: 28rpx;
  line-height: 1.82;
}

.project-card {
  padding: 34rpx 32rpx;
}

.project-card-primary {
  border-color: rgba(212, 175, 55, .16);
  background: rgba(255, 255, 255, .045);
}

.project-card-secondary {
  background: rgba(255, 255, 255, .032);
}

.project-card + .project-card {
  margin-top: 30rpx;
}

.project-card .list-title {
  margin-bottom: 18rpx;
}
