<view class="page product-detail-page">
  <block wx:if="{{product}}">
    <view class="product-detail-hero">
      <image wx:if="{{product.cover_image}}" class="cover hero-cover" mode="aspectFill" lazy-load src="{{product.cover_image}}" />
      <view class="hero-title">{{product.title}}</view>
      <view class="subtitle">{{product.subtitle}}</view>
    </view>

    <view class="card product-detail-panel">
      <view class="price">{{product.price_text}}</view>
      <view class="meta">酒瓶星贴 · {{product.sticker_count}} 枚 · 不含酒水</view>
      <view class="hint">{{product.description}}</view>
      <view class="hint">{{product.shipping_note}}</view>
      <view class="hint">{{product.after_sale_note}}</view>
      <block wx:for="{{product.images}}" wx:key="*this">
        <image class="cover detail-image" mode="widthFix" lazy-load src="{{item}}" />
      </block>
      <button class="btn" bindtap="buyNow">立即购买</button>
      <view class="meta">购买的是酒瓶星贴/印刷贴纸，不含酒水。</view>
    </view>
  </block>

  <view wx:if="{{message}}" class="meta state-card">{{message}}</view>
</view>
